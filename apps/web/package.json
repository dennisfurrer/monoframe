{
  "name": "@monoframe/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "git clean -xdf .cache .next .turbo node_modules",
    "dev": "next dev --port ${PORT:-3000}",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --check . --ignore-path=../../.gitignore",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@monoframe/db": "workspace:*",
    "@monoframe/ui-atoms": "workspace:*",
    "@monoframe/ui-molecules": "workspace:*",
    "clsx": "^2.1.1",
    "next": "16.1.6",
    "react": "catalog:react19",
    "react-dom": "catalog:react19"
  },
  "devDependencies": {
    "@monoframe/eslint-config": "workspace:*",
    "@monoframe/prettier-config": "workspace:*",
    "@monoframe/tsconfig": "workspace:*",
    "@monoframe/tailwind-config": "workspace:*",
    "@types/node": "^22.15.29",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "eslint": "catalog:",
    "postcss": "^8.5.4",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "prettier": "@monoframe/prettier-config"
}
