{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": [".env*"],
  "globalEnv": ["NODE_ENV", "PORT", "DATABASE_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "^db:generate"],
      "outputs": [".cache/tsbuildinfo.json", "dist/**", ".next/**", "generated/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "dependsOn": ["^db:generate"],
      "cache": false,
      "outputs": ["generated/**", "node_modules/.prisma/**"]
    },
    "db:migrate": {
      "cache": false
    },
    "db:deploy": {
      "cache": false
    },
    "format": {
      "outputs": [".cache/.prettiercache/**"],
      "outputLogs": "new-only"
    },
    "lint": {
      "dependsOn": ["@monoframe/db#db:generate"],
      "outputs": [".cache/.eslintcache/**"]
    },
    "typecheck": {
      "dependsOn": ["@monoframe/db#db:generate"],
      "outputs": [".cache/tsbuildinfo.json"]
    },
    "test": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
