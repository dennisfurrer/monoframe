{
  "name": "@monoframe/db",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "postinstall": "echo 'Skipping prisma generate during install - run db:generate manually'",
    "clean": "git clean -xdf .cache .turbo dist generated node_modules",
    "db:generate": "pnpm prisma generate",
    "db:migrate": "pnpm with-env prisma migrate dev",
    "db:deploy": "pnpm with-env prisma migrate deploy",
    "db:studio": "pnpm with-env prisma studio",
    "db:reset": "pnpm with-env prisma migrate reset",
    "format": "prisma format && prettier --check ./src --ignore-path ../../.gitignore",
    "lint": "eslint ./src",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^6.14.0",
    "@prisma/client": "^6.14.0"
  },
  "devDependencies": {
    "@monoframe/eslint-config": "workspace:*",
    "@monoframe/prettier-config": "workspace:*",
    "@monoframe/tsconfig": "workspace:*",
    "dotenv-cli": "^10.0.0",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "prisma": "^6.14.0",
    "tsx": "^4.20.3",
    "typescript": "catalog:"
  },
  "prettier": "@monoframe/prettier-config"
}
